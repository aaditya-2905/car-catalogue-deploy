{
    "family": "project-1-taskdef",
    "taskRoleArn": "arn:aws:iam::383465661937:role/ecsTaskExecutionRole",
    "executionRoleArn": "arn:aws:iam::383465661937:role/ecsTaskExecutionRole",
    "networkMode": "awsvpc",
    "containerDefinitions": [
        {
            "name": "project1",
            "image": "383465661937.dkr.ecr.ap-south-1.amazonaws.com/car-catalogue:latest",
            "cpu": 0,
            "portMappings": [
                {
                    "containerPort": 80,
                    "hostPort": 80,
                    "protocol": "tcp"
                }
            ],
            "essential": true,
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/project-1-taskdef",
                    "awslogs-region": "ap-south-1",
                    "awslogs-stream-prefix": "ecs"
                }
            }
        }
    ],
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "1024",
    "memory": "3072"
}
